# Backend Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

# ── Server ────────────────────────────────────────────────────
PORT=5000

# ── AI Providers ──────────────────────────────────────────────
# Primary: Google Gemini (required)
# Get your key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Fallback: Groq (free, fast — key starts with gsk_)
# Get your key from: https://console.groq.com/keys
# OR Fallback: xAI Grok (key starts with xai-)
# Get your key from: https://console.x.ai/
GROK_API_KEY=gsk_your_groq_key_here

# ── MongoDB ───────────────────────────────────────────────────
# Production: MongoDB Atlas connection string
# Without this, the server falls back to in-memory MongoDB (dev only)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/SkillsGap?retryWrites=true&w=majority

# ── CORS ──────────────────────────────────────────────────────
# Set this to your production frontend URL (comma-separated for multiple)
# Example: https://skillgap-ai.vercel.app
# localhost origins are always allowed automatically.
CORS_ORIGIN=https://your-frontend-domain.com
